# Secrets / local environment (excluded from git — см. .gitignore:138)

# Ключ для защищённых /admin/* эндпоинтов и override_time/override_weather в /path
ADMIN_API_KEY=

# OpenWeather API ключ для автообновления текущей погоды.
# Получить бесплатно: https://openweathermap.org/api (план "Free", 1000 запросов/день).
# Пустое значение = автообновление выключено, погода управляется вручную через
# PUT /admin/weather или через UI FactorsPanel (таб «Погода»).
OPENWEATHER_API_KEY=

# Координаты центра Москвы и интервал опроса — оставить дефолтными, если не нужно менять.
# OPENWEATHER_LAT=55.7522
# OPENWEATHER_LON=37.6156
# WEATHER_REFRESH_MINUTES=15
